# Configuration file for Password Strength Analyzer

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Configuration (allow frontend to connect)
CORS_ORIGINS=*

# Security
ENABLE_HTTPS=False  # Set to True in production

# Password Analysis Settings
ATTEMPTS_PER_SECOND=1000000  # 1 million attempts/second assumption
MAX_PASSWORD_LENGTH=128
MIN_PASSWORD_LENGTH=1

# History Settings
MAX_HISTORY_ENTRIES=50

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Version
VERSION=1.0.0
APP_NAME=Password Strength Analyzer
